NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/exam_prep
# Fallback if mongodb+srv DNS fails (ECONNREFUSED)
MONGODB_URI_FALLBACK=mongodb://127.0.0.1:27017/exam_prep
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# Cheap model for AI Mentor chat (low token cost)
OPENROUTER_MENTOR_MODEL=google/gemini-2.5-flash-lite
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@examprep.com
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000
